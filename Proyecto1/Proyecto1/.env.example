# Capa de Acceso a Datos (MongoDB Local o Atlas)
# Para conectar a MongoDB Atlas en producción, reemplaza con tu URI Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=invernadero_iot

# Orígenes CORS permitidos (Frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Capa de Comunicación (MQTT - EMQX Broker Público de Desarrollo)
# Nota: La Raspberry Pi y el Backend deben compartir estas mismas credenciales.
ENABLE_MQTT=true
MQTT_HOST=broker.emqx.io
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=grupo17/invernadero
