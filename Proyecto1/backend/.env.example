# Configuración de Base de Datos (MongoDB Local o Atlas)
# Para Atlas en producción: mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=invernadero_iot

# CORS (backend en puerto 8080: uvicorn --host 127.0.0.1 --port 8080 --no-access-log)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MQTT — broker público EMQX (Python :1883, MQTTX Web WSS :8084)
ENABLE_MQTT=true
MQTT_HOST=broker.emqx.io
MQTT_PORT=1883
MQTT_PORT_SSL=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=grupo17/invernadero

# Logging
LOG_LEVEL=INFO
