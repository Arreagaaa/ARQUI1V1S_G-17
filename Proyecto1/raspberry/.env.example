# Conectividad con la API REST del Backend
BACKEND_URL=http://localhost:8000

# Conectividad MQTT (Broker HiveMQ Cloud — mismo que el backend)
MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=grupo17/invernadero
DEVICE_ID=raspi-01

# Hardware (false = simulación / dry-run; true = en Raspberry Pi 3/4)
ENABLE_GPIO=false
POLL_INTERVAL_SECONDS=15

# --- Subsistema de Riego (1 bomba + 1 válvula física) ---
# Área 2 es riego manual/simulado; las áreas NO se riegan en paralelo.
GPIO_PUMP=17                 # Relé de la bomba (1 sola)
GPIO_VALVE_AREA_1=27         # Válvula selectora Área 1
GPIO_VALVE_AREA_2=22         # (no instalada físicamente — pin dummy)
GPIO_FAN=23                  # Ventilador DC
GPIO_LIGHTS=24               # LEDs blancos de iluminación
GPIO_BUZZER=25               # Buzzer de alarma

# --- LEDs de estado global (3 LEDs) ---
GPIO_LED_GREEN=5             # Estado NORMAL
GPIO_LED_YELLOW=6            # ADVERTENCIA / RIEGO_ACTIVO
GPIO_LED_RED=12              # EMERGENCIA

# --- Pantalla LCD 16x2 ---
# Por defecto se usa I2C backpack (rpi_lcd: address 0x27, bus 1).
# Los pines paralelo son fallback si no hay I2C.
LCD_RS=13
LCD_E=19
LCD_D4=16
LCD_D5=20
LCD_D6=21
LCD_D7=0                    # GPIO 0 (ID_SD) — solo para fallback paralelo

# --- Botones físicos de control (4 botones, pull-up) ---
# Todos en pines ÚNICOS — sin conflictos con actuadores.
BUTTON_MODE=4                # Botón 1: alternar auto/manual
BUTTON_PUMP_MANUAL=8         # Botón 2: riego manual (solo en modo manual)
BUTTON_LIGHTS_MANUAL=18      # Botón 3: encender/apagar luces
BUTTON_SILENCE=15            # Botón 4: silenciar buzzer

# --- Sensores ---
# DHT11/22: pin de datos (GPIO) — único, sin conflicto
DHT_GPIO=26                  # DHT11/22 data pin

# Sensores analógicos vía ADC MCP3008 (SPI, canales 0-3)
# Los valores NO son GPIO, son NÚMEROS DE CANAL del MCP3008 (0-7).
LDR_ADC_CH=0                 # LDR — canal 0
SOIL_ADC_CH1=1               # Higrómetro Área 1 — canal 1
SOIL_ADC_CH2=2               # Higrómetro Área 2 — canal 2
MQ_ADC_CH=3                  # MQ-2/135 gas — canal 3

# --- SPI (software bit-banging para MCP3008) ---
# Pines GPIO para emular SPI. Por defecto usa hardware SPI del Pi 3/4.
# Si se cambian, deben ser pines GPIO digitales libres.
SPI_MOSI=10
SPI_MISO=9
SPI_SCLK=11
SPI_CE=7                     # Chip Enable (CE1 en hardware SPI)
