# Conectividad con la API REST del Backend
BACKEND_URL=http://localhost:8000

# Conectividad MQTT (Broker EMQX de Desarrollo)
# Debe coincidir exactamente con la del backend (prefijo según enunciado: "invernadero")
MQTT_HOST=broker.emqx.io
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=grupo17/invernadero
DEVICE_ID=raspi-01

# Hardware (false = simulación / dry-run en PC de desarrollo; true = en Raspberry Pi 3/4)
ENABLE_GPIO=false
POLL_INTERVAL_SECONDS=15

# --- Subsistema de Riego (SIMPLIFICADO a 1 sola bomba) ---
# El enunciado/permiso indica UNA sola bomba de agua y UNA sola válvula física.
# Área 2 se maneja como riego manual/simulado en dashboard y lógica.
# Las áreas NO se riegan en paralelo.
GPIO_PUMP=17                 # Relé de la bomba (1 sola)
GPIO_VALVE_AREA_1=27         # Válvula selectora Área 1
GPIO_VALVE_AREA_2=22         # Válvula selectora Área 2
GPIO_FAN=23                  # Ventilador DC
GPIO_LIGHTS=24               # LEDs blancos de iluminación
GPIO_BUZZER=25               # Buzzer de alarma

# --- LEDs de estado global (3 LEDs obligatorios) ---
GPIO_LED_GREEN=5             # Estado NORMAL
GPIO_LED_YELLOW=6            # ADVERTENCIA / RIEGO_ACTIVO
GPIO_LED_RED=12              # EMERGENCIA

# --- Pantalla LCD 16x2 (rotativa) ---
LCD_RS=13
LCD_E=19
LCD_D4=16
LCD_D5=20
LCD_D6=21
LCD_D7=26

# --- Botones físicos de control (mínimo 4) ---
BUTTON_MODE=4                # Botón 1: alternar auto/manual
BUTTON_PUMP_MANUAL=17        # Botón 2: riego manual (alterna Área 1/Área 2)
BUTTON_LIGHTS_MANUAL=18      # Botón 3: encender/apagar luces
BUTTON_SILENCE=23            # Botón 4: silenciar buzzer / restablecer alerta
# BUTTON_FAN=24              # Botón 5 (opcional): ventilación manual

# --- Sensores ---
DHT_GPIO=27                  # DHT11/22 (data pin)
LDR_GPIO=14                  # LDR (ADC MCP3008 channel 0 en Pi 3/4 sin ADC nativo)
SOIL_GPIO_A1=2               # Sensor suelo Área 1 (ADC ch 1)
SOIL_GPIO_A2=3               # Sensor suelo Área 2 (ADC ch 2)
MQ_GPIO=4                    # MQ-2/135 (ADC ch 3)
